# Ignore everything in figures directory except PNGs and TEX files
docs/figures/*
!docs/figures/*.png
!docs/figures/*.tex

local/

# Matplotlib font/cache when MPLCONFIGDIR points under the repo
.matplotlib/

# Notebook / TCIA cache and experiment outputs
data/cache/
# Track selected notebook run summaries/visualizations; ignore other results/
results/*
!results/notebook_runs/
results/notebook_runs/*
!results/notebook_runs/20260409_191733/
results/notebook_runs/20260409_191733/*
!results/notebook_runs/20260409_191733/combined_summary.json
!results/notebook_runs/20260409_191733/comparison/
figures/

# Editable install metadata (regenerated by pip install -e .)
*.egg-info/